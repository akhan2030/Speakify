# Copy to Vercel → Project → Settings → Environment Variables
# Do NOT commit real secrets to GitHub.

NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=https://speakify.com
AUTH_TRUST_HOST=true

SUPABASE_URL=https://your-project.supabase.co/rest/v1/
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

OPENAI_API_KEY=your-openai-key
OPENAI_ASSISTANT_ID=your-assistant-id
OPENAI_SPEAKING_ASSISTANT_ID=your-speaking-assistant-id
OPENAI_SPEAKING_EVALUATOR_VERSION=v2-official-flexible

# Teacher invite emails (https://resend.com). Without this, invite links are shown in the admin UI only.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Speakify LMS <onboarding@your-verified-domain.com>
