# Copy to Vercel → Project → Settings → Environment Variables
# Do NOT commit real secrets to GitHub.

NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=https://speakify.com
AUTH_TRUST_HOST=true

SUPABASE_URL=https://your-project.supabase.co/rest/v1/
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

OPENAI_API_KEY=your-openai-key
OPENAI_ASSISTANT_ID=your-assistant-id
OPENAI_SPEAKING_ASSISTANT_ID=your-speaking-assistant-id
OPENAI_SPEAKING_EVALUATOR_VERSION=v2-official-flexible

# Sarah examiner voice — ElevenLabs for paid/comped students (Sarah Pro tier)
# Get API key + voice ID at https://elevenlabs.io
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Local dev only — never set in Vercel production. Shows quick demo sign-in on /login.
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true

# Passwords for demo/admin accounts used by `npm run seed:users`. Leave unset to
# skip seeding those accounts. Rotate live passwords with
# `node scripts/rotate-demo-passwords.mjs`. Never commit real values.
# DEMO_ADMIN_PASSWORD=set-a-strong-password
# DEMO_STUDENT_PASSWORD=set-a-strong-password

# Teacher invite + password reset emails (https://resend.com).
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Speakify LMS <onboarding@your-verified-domain.com>

# Password reset WhatsApp OTP — Meta WhatsApp Cloud API (recommended; free tier)
# Setup: https://developers.facebook.com/apps → Create App → Add WhatsApp product
# From API Setup page copy Phone number ID + generate access token (test) or System User token (prod)
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_permanent_access_token
WHATSAPP_OTP_TEMPLATE_NAME=hello_world
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en_US
# Optional: use authentication template after Meta approves it
# WHATSAPP_OTP_TEMPLATE_NAME=authentication

# Password reset WhatsApp/SMS OTP — option B: Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=+1234567890
